### Create shipment
POST http://localhost:8081/api/parcels
Content-Type: application/json

{
  "trackingNumber": "INPOST001",
  "status": "CREATED",
  "senderName": "Jan Kowalski",
  "senderPhone": "+48111222333",
  "recipientName": "Anna Nowak",
  "recipientPhone": "+48444555666",
  "deliveryType": "COURIER",
  "weight": 1.25,
  "sizeCategory": "M"
}

### Get all shipments
GET http://localhost:8081/api/parcels

### Get shipment by tracking number
GET http://localhost:8081/api/parcels/tracking/INPOST001

### Update shipment status
PATCH http://localhost:8081/api/parcels/{{shipmentId}}/status
Content-Type: application/json

{
  "status": "IN_TRANSIT"
}

### Delete shipment
DELETE http://localhost:8081/api/parcels/{{shipmentId}}

### Create point
POST http://localhost:8081/api/points
Content-Type: application/json

{
  "name": "Warsaw Locker 01",
  "type": "PARCEL_LOCKER",
  "city": "Warsaw",
  "address": "Marszalkowska 1",
  "postalCode": "00-001",
  "active": true
}

### Get all points
GET http://localhost:8081/api/points

### Create user
POST http://localhost:8081/api/users
Content-Type: application/json

{
  "firstName": "Roman",
  "lastName": "Nowak",
  "email": "roman@example.com",
  "phone": "+48123123123"
}

### Get all users
GET http://localhost:8081/api/users

### Add tracking event
POST http://localhost:8081/api/tracking
Content-Type: application/json

{
  "shipmentId": "{{shipmentId}}",
  "status": "IN_TRANSIT",
  "locationName": "Warsaw Sorting Center",
  "description": "Shipment scanned at sorting center"
}

### Get tracking history
GET http://localhost:8081/api/tracking/{{shipmentId}}

### Create complaint
POST http://localhost:8081/api/complaints
Content-Type: application/json

{
  "shipmentId": "{{shipmentId}}",
  "userId": "{{userId}}",
  "type": "DAMAGED",
  "description": "Box arrived damaged"
}

### Get complaints
GET http://localhost:8081/api/complaints

### Create offline payment
POST http://localhost:8081/api/payments
Content-Type: application/json

{
  "shipmentId": "{{shipmentId}}",
  "amount": 29.99,
  "method": "OFFLINE"
}

### Get payments
GET http://localhost:8081/api/payments?shipmentId={{shipmentId}}

### Confirm offline payment
PATCH http://localhost:8081/api/payments/{{paymentId}}/confirm-offline
